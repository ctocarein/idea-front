# Front Ideaxion — variables d'environnement (staging). À fournir au runtime du conteneur.
# Aucune n'est exposée au navigateur (server-only) — le BFF est la seule couche qui appelle le backend.

# URL interne/DNS du backend FastAPI (sans /api/v1 : les chemins OpenAPI l'incluent).
BACKEND_API_URL=https://api-staging.ideaxion.app

# Toujours "production" pour un déploiement (active cookies Secure, désactive les devtools).
NODE_ENV=production
